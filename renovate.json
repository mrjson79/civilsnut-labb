{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Renovate configuration for civilsnut-labbet Kubernetes cluster",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":automergeBranch"
  ],
  "timezone": "Europe/Stockholm",
  "minimumReleaseAge": "3 days",
  "dependencyDashboardAutoclose": true,
  "prConcurrentLimit": 5,
  "prHourlyLimit": 3,
  "platformAutomerge": true,
  "gitAuthor": "Renovate Bot <renovate@civilsnut.com>",
  "commitMessagePrefix": "chore:",
  "commitMessageTopic": "{{depName}}",
  "commitMessageExtra": "to {{newVersion}}",
  "labels": ["dependencies"],
  "assignees": ["mrjson79"],
  "reviewers": ["mrjson79"],
  "ignorePaths": [
    "fluxcd/01-infrastructure/external-dns/**",
    "talos/**"
  ],
  "vulnerabilityAlerts": {
    "labels": ["security", "dependencies"],
    "assignees": ["mrjson79"],
    "reviewers": ["mrjson79"],
    "schedule": ["at any time"]
  },
  "flux": {
    "fileMatch": ["fluxcd/.+\\.ya?ml$"]
  },
  "kubernetes": {
    "fileMatch": ["fluxcd/.+\\.ya?ml$"]
  },
  "packageRules": [
    {
      "description": "Automerge digest updates",
      "matchUpdateTypes": ["digest"],
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "description": "Critical security components - require manual review",
      "matchPackageNames": ["cert-manager", "external-secrets"],
      "automerge": false,
      "labels": ["security-critical"],
      "groupName": "Security Infrastructure"
    },
    {
      "description": "Networking components",
      "matchPackageNames": ["cilium"],
      "labels": ["networking"],
      "automerge": false,
      "groupName": "Networking Stack"
    },
    {
      "description": "Monitoring stack",
      "matchPackageNames": ["victoria-metrics-k8s-stack"],
      "labels": ["monitoring"],
      "groupName": "Monitoring Stack",
      "schedule": ["before 6am on saturday"]
    },
    {
      "description": "Storage components",
      "matchPackageNames": ["rook-ceph", "rook-ceph-cluster"],
      "labels": ["storage"],
      "automerge": false,
      "groupName": "Storage Stack"
    },
    {
      "description": "Home automation",
      "matchPackageNames": [
        "home-assistant",
        "ghcr.io/home-assistant/home-assistant",
        "zigbee2mqtt",
        "eclipse-mosquitto"
      ],
      "labels": ["home-automation"],
      "groupName": "Home Automation",
      "schedule": ["before 6am on saturday"]
    },
    {
      "description": "Container images - patch updates can be auto-merged",
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["patch", "digest"],
      "automerge": true,
      "automergeType": "branch",
      "labels": ["container-images", "automerge"]
    },
    {
      "description": "Non-critical Helm minor/patch - automerge for homelab",
      "matchDatasources": ["helm"],
      "matchUpdateTypes": ["minor", "patch"],
      "excludePackageNames": [
        "cert-manager", "external-secrets",
        "cilium",
        "rook-ceph", "rook-ceph-cluster"
      ],
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "description": "All other minor/patch updates",
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Other Dependencies",
      "groupSlug": "other-deps"
    },
    {
      "description": "Major updates require careful review",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["major-update"]
    }
  ],
  "hostRules": [
    {
      "matchHost": "/^(charts\\.(jetstack|external-secrets|rook|zigbee2mqtt)\\.io|helm\\.cilium\\.io|(kubernetes|victoriametrics|1password)\\.github\\.io)$/",
      "timeout": 30000
    }
  ],
  "ignoreDeps": ["localhost/**", "*:latest", "*:main"]
}
